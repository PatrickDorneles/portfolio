# Copy to .env or .env.local. Turso: use the libsql:// URL and token from the Turso dashboard.

# Local: SQLite file (then run npm run db:push && npm run db:seed)
DATABASE_URL="file:./.data/local.db"

# Turso — required for remote libsql:// URLs, omit for file: local DB
# TURSO_AUTH_TOKEN=

# Public profile
# NEXT_PUBLIC_PROFILE_NAME=
# NEXT_PUBLIC_PROFILE_TITLE=
# NEXT_PUBLIC_PROFILE_IMAGE=
# NEXT_PUBLIC_GITHUB_URL=
# NEXT_PUBLIC_LINKEDIN_URL=
# NEXT_PUBLIC_EMAIL=
